<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtEssStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ess : receiver actif"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="20dp"
        android:background="#1E1E1E"
        android:layout_marginBottom="30dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="1"
        android:rowCount="2">

        <Button
            android:id="@+id/btnEssActivation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activer Receiver ESS"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7C4DFF"
            android:padding="18dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnEssBroadcast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Envoyer Broadcast ESS"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6200EA"
            android:padding="18dp"/>
    </GridLayout>

</LinearLayout>